; Write an X86/64 ALP to find the largest of given Byte/Word/Dword/64bit numbers

section .data
  array db 22h,99h,60h,22h,14h
  
  msg1 db 10,"ALP to find the largest number in an array",10
  msg1_len equ $ - msg1
  
  msg2 db 10,"the array contains the element:",10
  msg2_len equ $ - msg2
  
  msg3 db 10,10,"the largest number in the array is:",10
  msg3_len equ $ - msg3
  
  new_line db 10
  new_len equ $ - new_line

section .bss
  counter resb 1
  result resb 4
  
%macro write 2
  mov rax,1
  mov rdi,1
  mov rsi,%1
  mov rdx,%2
  syscall
%endmacro

section .text
   global _start
  
_start:
    write msg1,msg1_len
    write msg2,msg2_len
    mov byte[counter],05
    mov rsi,array           ;rsi points to start of the array

next: mov al,[rsi]          ; load cuttent ele into AL
    push rsi                ; save rsi (as disp modifies register)
    call disp               ; call disp subroutine to print element
    write new_line,new_len
    
    pop rsi                 ; restore rsi
    inc rsi                 ; move to next ele
    dec byte[counter]       ; repeat until counter=0
    jnz next
    
    write msg3,msg3_len
    
    mov byte[counter],05
    mov rsi,array
    mov al,0                 ; al is an 8 bit register, al stores max
repeat: cmp al,[rsi]         ; cmp opr1,opr2 : opr1-opr2 comapare al
      jg skip                ; if al>[rsi], skip update
      mov al,[rsi]           ; otherwise update max
skip: inc rsi
       dec byte[counter]      ; continue until all elements checked
       jnz repeat
       
       call disp
        write new_line,new_len
       
       mov rax,60
       mov rdi,1
       syscall
    
disp:
     mov bl,al            ; store number in bl
     mov rdi,result       ; point rdi to result variable
     mov cx,02            ; load count of rotation in cl
     
up1:
   
  rol bl,04               ; rotate number left by four bits
  mov al,bl               ; move lower byte in dl
  and al,0fh              ; get only LSB
  cmp al, 09h             ; comapre with 09h
  jg add_37               ; if grater than 39h skip add37
  add al,30h              ; convert 0-9 to ASCII
  jmp skip1               ; else add 30
add_37:add al,37h         ; convert A-F to ASCII     
  
skip1:mov[rdi],al         ; store ascii code in result variabl
       inc rdi            ; point to next byte
       dec cx             ; decrement the count of digits to display
       jnz up1            ; if not zero jump to repeat
       
       write result,4
       
       ret
    

